<!-- CRAIC 比赛第一版：真实调用 EgoApi 飞行，MID360 点云识别柱子，
     D435 深度图通过 override 任务闭环穿框。 -->
<launch>
    <arg name="bridge_ns" default="/ego_bridge" />
    <arg name="flight_z" default="0.9" />
    <arg name="takeoff_height" default="0.65" />
    <arg name="land_after_finish" default="true" />
    <arg name="start_ego_planner" default="true" />
    <arg name="start_ego_bridge" default="true" />
    <arg name="climb_to_flight_z_before_detect" default="true" />
    <arg name="override_climb_timeout" default="10.0" />
    <arg name="override_climb_speed" default="0.18" />
    <arg name="pillar_valid_max_age" default="0.5" />
    <arg name="pillar_valid_count_required" default="5" />
    <arg name="pillar_align_timeout" default="25.0" />
    <arg name="pillar_align_threshold" default="0.12" />
    <arg name="pillar_align_speed" default="0.10" />
    <arg name="pillar_align_kp" default="0.65" />
    <arg name="pillar_align_z_kp" default="0.9" />
    <arg name="pillar_align_max_vz" default="0.12" />
    <arg name="pillar_align_yaw_kp" default="0.6" />
    <arg name="pillar_align_max_yaw_rate" default="0.25" />
    <arg name="pillar_align_yaw_threshold" default="0.20" />
    <arg name="pillar_align_hold_time" default="0.8" />
    <arg name="enable_pillar_active_scan" default="true" />
    <arg name="pillar_active_scan_delay" default="3.0" />
    <arg name="pillar_scan_yaw_rate" default="0.35" />
    <arg name="pillar_scan_lateral_speed" default="0.06" />

    <arg name="raw_cloud_topic" default="/cloud_registered" />
    <arg name="cloud_topic" default="/craic/cloud_filtered" />
    <arg name="pillar_cloud_topic" default="/cloud_registered" />
    <arg name="odom_topic" default="/mavros/local_position/odom" />
    <arg name="depth_topic" default="/d435/depth/image_raw" />
    <arg name="camera_info_topic" default="/d435/depth/camera_info" />
    <arg name="use_local_rule_roi" default="false" />
    <arg name="field_length" default="6.0" />
    <arg name="field_width" default="5.0" />
    <arg name="pillar_search_forward_min" default="-0.25" />
    <arg name="pillar_search_forward_max" default="6.5" />
    <arg name="pillar_search_lateral_abs" default="3.0" />
    <arg name="pillar_roi_x_min" default="-0.3" />
    <arg name="pillar_roi_x_max" default="4.0" />
    <arg name="pillar_roi_y_min" default="-2.5" />
    <arg name="pillar_roi_y_max" default="2.5" />
    <arg name="pillar_roi_z_min" default="0.05" />
    <arg name="pillar_roi_z_max" default="1.9" />
    <arg name="pillar_voxel_leaf" default="0.06" />
    <arg name="pillar_width" default="0.50" />
    <arg name="pillar_min_visible_height" default="0.32" />
    <arg name="pillar_min_strong_height" default="0.50" />
    <arg name="pillar_full_min_width" default="0.25" />
    <arg name="pillar_full_max_width" default="0.75" />
    <arg name="pillar_face_span_min" default="0.25" />
    <arg name="pillar_face_span_max" default="0.75" />
    <arg name="pillar_thin_face_max_width" default="0.22" />
    <arg name="pillar_corner_max_width" default="0.28" />
    <arg name="pillar_long_reject_width" default="0.85" />
    <arg name="pillar_min_vertical_bins" default="2" />
    <arg name="pillar_min_cluster_size" default="10" />
    <arg name="pillar_max_cluster_size" default="8000" />
    <arg name="pillar_cluster_tolerance" default="0.28" />
    <arg name="pillar_pair_gap_min" default="0.8" />
    <arg name="pillar_pair_gap_max" default="2.8" />
    <arg name="pillar_pair_expected_gap" default="1.6" />
    <arg name="pillar_pair_forward_tolerance" default="1.0" />
    <arg name="pillar_goal_offset" default="0.90" />
    <arg name="pillar_stable_frames" default="3" />
    <arg name="pillar_history_size" default="5" />
    <arg name="pillar_stability_threshold" default="0.15" />

    <!-- 先过滤 MID360/FAST-LIO 点云里的机体附近点和异常高度点，避免 EGO 把自身刷成障碍。 -->
    <node pkg="ego_api" type="craic_cloud_self_filter" name="craic_cloud_self_filter" output="screen">
        <param name="input_cloud_topic" value="$(arg raw_cloud_topic)" />
        <param name="output_cloud_topic" value="$(arg cloud_topic)" />
        <param name="odom_topic" value="$(arg odom_topic)" />
        <param name="self_radius_xy" value="0.45" />
        <param name="self_radius_z" value="0.45" />
        <param name="min_z" value="0.03" />
        <param name="max_z" value="2.2" />
    </node>

    <!-- 拉起 EGO-Planner。当前仿真话题已经对齐：
         odom=/mavros/local_position/odom，cloud=/craic/cloud_filtered。 -->
    <include file="$(find ego_planner)/launch/single_run_in_exp.launch"
             if="$(arg start_ego_planner)">
        <arg name="cloud_topic" value="$(arg cloud_topic)" />
        <arg name="use_goal_msg_z" value="true" />
        <arg name="fixed_goal_z" value="$(arg flight_z)" />
    </include>

    <!-- 这里直接拉起 ego_bridge_node，而不是 include ego_bridge.launch。
         原 launch 还会 include 当前仿真环境里不存在的 lidar_to_mavros。 -->
    <group if="$(arg start_ego_bridge)">
        <rosparam file="$(find ego_bridge)/config/ego_bridge_param.yaml" command="load"
                  ns="ego_bridge" />
        <node pkg="ego_bridge" type="ego_bridge_node" name="ego_bridge" output="screen">
            <!-- api.takeoff() 的真正起飞完成高度：这里只控制起飞悬停高度，不等同于后续任务 flight_z。 -->
            <param name="takeoff/height" value="$(arg takeoff_height)" />
            <remap from="~odom" to="/mavros/local_position/odom" />
            <remap from="~cmd" to="/position_cmd" />
        </node>
    </group>

    <!-- MID360/FAST-LIO 点云柱子识别，稳定后发布 /craic/pillar_pre_goal 和 post_goal。 -->
    <node pkg="ego_api" type="craic_pillar_detector" name="craic_pillar_detector" output="screen">
        <param name="cloud_topic" value="$(arg pillar_cloud_topic)" />
        <param name="odom_topic" value="$(arg odom_topic)" />
        <param name="flight_z" value="$(arg flight_z)" />
        <param name="use_local_rule_roi" value="$(arg use_local_rule_roi)" />
        <param name="field_length" value="$(arg field_length)" />
        <param name="field_width" value="$(arg field_width)" />
        <param name="search_forward_min" value="$(arg pillar_search_forward_min)" />
        <param name="search_forward_max" value="$(arg pillar_search_forward_max)" />
        <param name="search_lateral_abs" value="$(arg pillar_search_lateral_abs)" />
        <param name="roi_x_min" value="$(arg pillar_roi_x_min)" />
        <param name="roi_x_max" value="$(arg pillar_roi_x_max)" />
        <param name="roi_y_min" value="$(arg pillar_roi_y_min)" />
        <param name="roi_y_max" value="$(arg pillar_roi_y_max)" />
        <param name="roi_z_min" value="$(arg pillar_roi_z_min)" />
        <param name="roi_z_max" value="$(arg pillar_roi_z_max)" />
        <param name="voxel_leaf" value="$(arg pillar_voxel_leaf)" />
        <param name="pillar_width" value="$(arg pillar_width)" />
        <param name="pillar_min_visible_height" value="$(arg pillar_min_visible_height)" />
        <param name="pillar_min_strong_height" value="$(arg pillar_min_strong_height)" />
        <param name="pillar_full_min_width" value="$(arg pillar_full_min_width)" />
        <param name="pillar_full_max_width" value="$(arg pillar_full_max_width)" />
        <param name="pillar_face_span_min" value="$(arg pillar_face_span_min)" />
        <param name="pillar_face_span_max" value="$(arg pillar_face_span_max)" />
        <param name="pillar_thin_face_max_width" value="$(arg pillar_thin_face_max_width)" />
        <param name="pillar_corner_max_width" value="$(arg pillar_corner_max_width)" />
        <param name="pillar_long_reject_width" value="$(arg pillar_long_reject_width)" />
        <param name="pillar_min_vertical_bins" value="$(arg pillar_min_vertical_bins)" />
        <param name="min_cluster_size" value="$(arg pillar_min_cluster_size)" />
        <param name="max_cluster_size" value="$(arg pillar_max_cluster_size)" />
        <param name="cluster_tolerance" value="$(arg pillar_cluster_tolerance)" />
        <param name="pillar_pair_gap_min" value="$(arg pillar_pair_gap_min)" />
        <param name="pillar_pair_gap_max" value="$(arg pillar_pair_gap_max)" />
        <param name="pillar_pair_expected_gap" value="$(arg pillar_pair_expected_gap)" />
        <param name="pair_forward_tolerance" value="$(arg pillar_pair_forward_tolerance)" />
        <param name="goal_offset" value="$(arg pillar_goal_offset)" />
        <param name="stable_frames" value="$(arg pillar_stable_frames)" />
        <param name="history_size" value="$(arg pillar_history_size)" />
        <param name="stability_threshold" value="$(arg pillar_stability_threshold)" />
    </node>

    <!-- override 任务节点：负责 D435 穿框，以及二维码/气球占位任务。 -->
    <node pkg="ego_api" type="override_task_demo" name="override_task_demo" output="screen">
        <param name="bridge_ns" value="$(arg bridge_ns)" />
        <param name="flight_z" value="$(arg flight_z)" />
        <param name="depth_topic" value="$(arg depth_topic)" />
        <param name="camera_info_topic" value="$(arg camera_info_topic)" />
    </node>

    <!-- 比赛主流程：起飞、等柱子、过柱、穿框、返程、回击打区、降落。 -->
    <node pkg="ego_api" type="craic_competition_demo" name="craic_competition_demo" output="screen">
        <param name="bridge_ns" value="$(arg bridge_ns)" />
        <param name="flight_z" value="$(arg flight_z)" />
        <param name="land_after_finish" value="$(arg land_after_finish)" />
        <param name="climb_to_flight_z_before_detect" value="$(arg climb_to_flight_z_before_detect)" />
        <param name="override_climb_timeout" value="$(arg override_climb_timeout)" />
        <param name="override_climb_speed" value="$(arg override_climb_speed)" />
        <param name="pillar_valid_max_age" value="$(arg pillar_valid_max_age)" />
        <param name="pillar_valid_count_required" value="$(arg pillar_valid_count_required)" />
        <param name="pillar_align_timeout" value="$(arg pillar_align_timeout)" />
        <param name="pillar_align_threshold" value="$(arg pillar_align_threshold)" />
        <param name="pillar_align_speed" value="$(arg pillar_align_speed)" />
        <param name="pillar_align_kp" value="$(arg pillar_align_kp)" />
        <param name="pillar_align_z_kp" value="$(arg pillar_align_z_kp)" />
        <param name="pillar_align_max_vz" value="$(arg pillar_align_max_vz)" />
        <param name="pillar_align_yaw_kp" value="$(arg pillar_align_yaw_kp)" />
        <param name="pillar_align_max_yaw_rate" value="$(arg pillar_align_max_yaw_rate)" />
        <param name="pillar_align_yaw_threshold" value="$(arg pillar_align_yaw_threshold)" />
        <param name="pillar_align_hold_time" value="$(arg pillar_align_hold_time)" />
        <param name="enable_pillar_active_scan" value="$(arg enable_pillar_active_scan)" />
        <param name="pillar_active_scan_delay" value="$(arg pillar_active_scan_delay)" />
        <param name="pillar_scan_yaw_rate" value="$(arg pillar_scan_yaw_rate)" />
        <param name="pillar_scan_lateral_speed" value="$(arg pillar_scan_lateral_speed)" />
    </node>
</launch>
