# Copy to /etc/default/craic-autostart and edit for the aircraft.

WORKSPACE_DIR=/home/orangepi/catkin_ws
ROS_DISTRO=noetic
ROS_RUN_USER=orangepi

# Preferred field Wi-Fi. If the profile has already been saved by NetworkManager,
# TARGET_WIFI_PASSWORD can stay empty.
TARGET_WIFI_SSID=316
TARGET_WIFI_PASSWORD=

# Leave WIFI_IFACE empty to auto-detect the first Wi-Fi device.
WIFI_IFACE=
WIFI_SCAN_TIMEOUT=20
WIFI_CONNECT_TIMEOUT=30

# Fallback hotspot when 316 is not visible or cannot be joined.
HOTSPOT_ENABLE=true
HOTSPOT_SSID=CRAIC_MID360
HOTSPOT_PASSWORD=12345678
HOTSPOT_CHANNEL=6
HOTSPOT_IP=192.168.66.1

# WEB_HOST_MODE=ip binds the web server to the selected aircraft IP.
# WEB_HOST_MODE=all binds to 0.0.0.0.
WEB_HOST_MODE=ip
WEB_HOST=
WEB_PORT=8088

ROS_MASTER_URI=http://127.0.0.1:11311
ROS_IP_AUTO=true
LAUNCH_GAP_SEC=3
PX4_FIRST_GAP_SEC=5

LIVOX_PACKAGE=livox_ros_driver2
LIVOX_LAUNCH=msg_MID360s.launch
MAVROS_PACKAGE=mavros
MAVROS_LAUNCH=px4.launch
LIDAR_TO_MAVROS_PACKAGE=lidar_to_mavros
LIDAR_TO_MAVROS_LAUNCH=fastlio_to_px4_mid360_direct.launch
WEB_PACKAGE=ego_api
WEB_LAUNCH=craic_web_control.launch
