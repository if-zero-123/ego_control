<launch>
  <arg name="depth_topic" default="/camera/depth/image_rect_raw" />
  <arg name="camera_info_topic" default="/camera/depth/camera_info" />
  <arg name="odom_topic" default="/mavros/local_position/odom" />
  <arg name="frame_id" default="" />

  <arg name="depth_min" default="0.35" />
  <arg name="depth_near_threshold" default="1.8" />
  <arg name="depth_max" default="3.0" />
  <arg name="min_open_width_px" default="70" />
  <arg name="min_open_height_px" default="70" />

  <arg name="roi_x_margin_ratio" default="0.20" />
  <arg name="roi_y_top_ratio" default="0.20" />
  <arg name="roi_y_bottom_ratio" default="0.10" />
  <arg name="row_open_ratio" default="0.65" />

  <arg name="pre_offset" default="0.60" />
  <arg name="post_offset" default="0.90" />
  <arg name="debug_log_period" default="1.0" />
  <arg name="depth_stale_timeout" default="1.0" />
  <arg name="publish_debug_image" default="true" />

  <node pkg="craic_pillar_debug" type="frame_debug_node" name="frame_debug_node" output="screen">
    <param name="depth_topic" value="$(arg depth_topic)" />
    <param name="camera_info_topic" value="$(arg camera_info_topic)" />
    <param name="odom_topic" value="$(arg odom_topic)" />
    <param name="frame_id" value="$(arg frame_id)" />

    <param name="depth_min" value="$(arg depth_min)" />
    <param name="depth_near_threshold" value="$(arg depth_near_threshold)" />
    <param name="depth_max" value="$(arg depth_max)" />
    <param name="min_open_width_px" value="$(arg min_open_width_px)" />
    <param name="min_open_height_px" value="$(arg min_open_height_px)" />

    <param name="roi_x_margin_ratio" value="$(arg roi_x_margin_ratio)" />
    <param name="roi_y_top_ratio" value="$(arg roi_y_top_ratio)" />
    <param name="roi_y_bottom_ratio" value="$(arg roi_y_bottom_ratio)" />
    <param name="row_open_ratio" value="$(arg row_open_ratio)" />

    <param name="pre_offset" value="$(arg pre_offset)" />
    <param name="post_offset" value="$(arg post_offset)" />
    <param name="debug_log_period" value="$(arg debug_log_period)" />
    <param name="depth_stale_timeout" value="$(arg depth_stale_timeout)" />
    <param name="publish_debug_image" value="$(arg publish_debug_image)" />
  </node>
</launch>
